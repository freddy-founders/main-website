# Browser-safe runtime values. Never commit service-role keys.
VITE_DATA_SOURCE=auto
VITE_SUPABASE_URL=https://vnhuiwxavsplhbmwvctx.supabase.co
VITE_SUPABASE_ANON_KEY=


# Server-only Cloudflare Worker secret. Set with `wrangler secret put`; never commit a value.
